# =============================================================
# N8N-Ollama 플랫폼 환경 변수 예시 파일
# 이 파일을 .env 로 복사한 후 값을 변경하세요
# cp .env.example .env
# =============================================================

# --- N8N 설정 ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=your-super-secret-encryption-key-change-this
WEBHOOK_URL=http://localhost:5678

# N8N 웹 UI 로그인 계정
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-admin-password

# 웹훅 API 인증 키 (모든 요청에 X-API-Key 헤더로 사용)
API_SECRET_KEY=your-api-secret-key

# --- Ollama 설정 ---
OLLAMA_BASE_URL=http://ollama:11434

# --- PostgreSQL 설정 ---
POSTGRES_DB=n8n_ollama
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_SCHEMA=public

# --- Redis 설정 ---
REDIS_PASSWORD=your-redis-password

# --- 대화 설정 ---
MAX_HISTORY_LENGTH=20
SESSION_TTL=86400

# --- 로깅 ---
N8N_LOG_LEVEL=info
